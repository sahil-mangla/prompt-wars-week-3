# Server Port
PORT=5001

# Gemini API Key (Required for AI features)
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Configuration
# Local emulator is enabled if FIREBASE_EMULATOR_HOST is set, else production Firebase is used
FIREBASE_DATABASE_URL=https://habitloop-carbon.firebaseio.com
GCP_PROJECT_ID=habitloop-carbon

# CORS: Frontend URL (production only — Firebase Hosting URL)
# Set this on Cloud Run to allow requests from your Firebase Hosting domain.
# Example: https://habitloop-carbon.web.app
# Leave unset in dev (wildcard is used automatically).
FRONTEND_URL=

# Service Account (production only)
# Do NOT commit service-account.json to git.
# Inject the JSON content via GCP Secret Manager and point
# GOOGLE_APPLICATION_CREDENTIALS to the file path at runtime.
# GOOGLE_APPLICATION_CREDENTIALS=/secrets/service-account.json
