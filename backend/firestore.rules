rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User profile: only the owner can read/write
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Weekly habit logs: only the owner can read/write their own logs
    match /users/{userId}/weeklyLogs/{logId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Global curated habits list: everyone can read, only admin can write
    match /habits/{habitId} {
      allow read: if request.auth != null;
      allow write: if false; // Admin write-only, client-side writes blocked
    }
  }
}
